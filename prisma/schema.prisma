generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Reparto {
  id               String   @id @default(cuid())
  codice           String   @unique
  nome             String
  tariffaMdo       Float    @default(0)   // €/ora — manodopera diretta
  oreCapacitaAnnua Float    @default(0)   // ore disponibili/anno (per tariffa CF)
  kWInstallata     Float    @default(0)   // kW potenza installata
  prezzoEnergia    Float    @default(0)   // €/kWh tariffa energia
  createdAt        DateTime @default(now())

  voceCostiFissi VoceCostoFisso[]
  macchine       Macchina[]
  fasi           FaseLavorazione[]
}

model Macchina {
  id                String  @id @default(cuid())
  repartoId         String
  codice            String  @unique
  nome              String
  capacitaMinGiorno Float   @default(480)  // minuti disponibili/giorno (8h = 480)

  reparto Reparto           @relation(fields: [repartoId], references: [id], onDelete: Cascade)
  fasi    FaseLavorazione[]
}

model Dipendente {
  id             String            @id @default(cuid())
  nome           String
  matricola      String            @unique
  efficienzaPerc Float             @default(100)
  costoOrario    Float             @default(0)

  skills SkillDipendente[]
}

model SkillDipendente {
  id           String     @id @default(cuid())
  dipendenteId String
  repartoId    String     // skill = sa lavorare in questo reparto

  dipendente Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)

  @@unique([dipendenteId, repartoId])
}

model VoceCostoFisso {
  id        String @id @default(cuid())
  repartoId String
  nome      String
  importo   Float  @default(0)   // €/anno

  reparto Reparto @relation(fields: [repartoId], references: [id], onDelete: Cascade)
}

model Prodotto {
  id            String    @id @default(cuid())
  codice        String    @unique
  nome          String
  cliente       String?
  quantita      Float     @default(1)
  dataInizio    DateTime?
  dataFine      DateTime?
  prezzoVendita Float?
  materiePrime  Float     @default(0)
  createdAt     DateTime  @default(now())

  fasi FaseLavorazione[]
}

// ── Fasi di lavorazione (sostituisce LavorazioneReparto + OperazioneCiclo) ─────
model FaseLavorazione {
  id         String    @id @default(cuid())
  prodottoId String
  repartoId  String
  macchinaId String?
  sequenza   Int                    // ordine esecuzione (1, 2, 3…)
  nome       String                 // es. "Taglio", "Confezione", "Ricamo"
  tempoOre   Float     @default(0)  // ore per pezzo

  prodotto Prodotto  @relation(fields: [prodottoId], references: [id], onDelete: Cascade)
  reparto  Reparto   @relation(fields: [repartoId], references: [id])
  macchina Macchina? @relation(fields: [macchinaId], references: [id], onDelete: SetNull)

  @@unique([prodottoId, sequenza])
}

model Configurazione {
  id            String @id @default("main")
  percAmmComm   Float  @default(15)
  ammCommTipo   String @default("PERC")   // "PERC" | "VALORE"
  ammCommValore Float  @default(0)        // €/anno
  baseRiparto   String @default("ORE_MACCHINA")
}
